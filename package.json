{
  "name": "famtree-server",
  "version": "1.0.0",
  "description": "FamTree Backend API - Serverless + PostgreSQL + TypeScript",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsoa spec-and-routes && tsc",
    "dev": "nodemon",
    "start": "node dist/app.js",
    "swagger": "tsoa spec",
    "routes": "tsoa routes",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "deploy:dev": "rm -rf .build && serverless deploy --stage dev",
    "deploy:prod": "rm -rf .build && serverless deploy --stage prod"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.15.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "nodemailer": "^6.10.1",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.4.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^6.4.23",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "serverless": "^3.39.0",
    "serverless-offline": "^13.3.0",
    "serverless-plugin-typescript": "^2.1.5",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "FamTree Team",
  "license": "MIT"
}
