# Database
DATABASE_URL="postgresql://username:password@localhost:5432/famtree?schema=public"

# JWT (openssl rand -hex 64 으로 생성)
JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"

# AWS Cognito
COGNITO_USER_POOL_ID="ap-northeast-2_xxxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_REGION="ap-northeast-2"

# Environment
NODE_ENV="dev"
PORT=3000
