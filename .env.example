# ============================================================
# Mongle Server 환경 변수 템플릿
# 사용법: cp .env.example .env 후 실제 값으로 채우기
# ⚠️  .env 파일은 절대 git에 커밋하지 말 것 (.gitignore 처리됨)
# ============================================================

# Database (AWS RDS PostgreSQL)
DATABASE_URL="postgresql://username:password@host:5432/mongle?schema=public"

# JWT Signing Keys
# 생성 방법: openssl rand -hex 64
JWT_SECRET="your-jwt-secret-64-bytes-hex"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-64-bytes-hex"

# AWS Cognito (선택 — Cognito User Pool 사용 시)
COGNITO_USER_POOL_ID="ap-northeast-2_xxxxxxxxx"
COGNITO_REGION="ap-northeast-2"

# Firebase Admin SDK (FCM 푸시 알림)
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# APNs (iOS 푸시 알림 — 사용 시)
APNS_BUNDLE_ID="app.monggle.mongle"
APNS_TEAM_ID="XXXXXXXXXX"
APNS_KEY_ID="XXXXXXXXXX"
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 소셜 로그인 audience 검증 (Phase 1 보안 강화 후 필수)
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"
APPLE_BUNDLE_ID="app.monggle.mongle"
KAKAO_REST_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# CORS 허용 origin (콤마 구분)
ALLOWED_ORIGINS="https://mongle.app,https://monggle.app"

# 이메일 인증 발송용 SMTP (회원가입 6자리 코드)
# 미설정 시 개발 환경에서는 콘솔에 코드만 출력하고 메일을 발송하지 않음 (dev fallback)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Mongle <no-reply@mongle.app>"

# Environment
NODE_ENV="dev"
PORT=3000
